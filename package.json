{
  "name": "satteri-stream",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "A Satteri-backed Streamdown-compatible streaming Markdown renderer.",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.11.0"
  },
  "license": "MIT",
  "author": "shlroland",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shlroland/satteri-stream.git"
  },
  "bugs": {
    "url": "https://github.com/shlroland/satteri-stream/issues"
  },
  "homepage": "https://github.com/shlroland/satteri-stream#readme",
  "keywords": [
    "markdown",
    "streaming",
    "react",
    "satteri",
    "streamdown"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "check": "pnpm typecheck && pnpm build && pnpm test"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "domhandler": "^6.0.1",
    "htmlparser2": "^12.0.0",
    "katex": "^0.16.22",
    "marked": "^17.0.1",
    "remend": "^1.3.0",
    "satteri": "^0.9.4"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "streamdown": "^2.5.0",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
